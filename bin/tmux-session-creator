#!/bin/bash

init_path=$1
find_level=$2
echo $find_level
path=$(find ${init_path} -mindepth ${find_level} -maxdepth ${find_level} -type d | fzf)
dirname=$(basename "$path")
if [[ "$dirname" == "grupa.furgonetka.pl.branches" || "$dirname" == "microservices" ]]; then
    path=$(find "${path}" -mindepth 1 -maxdepth 1 -type d | fzf)
fi
if [ -n $path ]; then
    new_session=$(tmux new-session -c ${path} -s "${dirname}" -d -P)
    if [ -z $TMUX ]; then
        tmux attach-session -t "${new_session}"
    else
        tmux switch -t "${new_session}"
    fi
fi

